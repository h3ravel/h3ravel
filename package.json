{
  "name": "h3ravel",
  "version": "1.29.0-alpha.16",
  "description": "Modern TypeScript runtime-agnostic web framework built on top of H3.",
  "type": "module",
  "main": "dist/index.js",
  "private": true,
  "categories": [
    "Programming Languages",
    "Extension Packs"
  ],
  "keywords": [
    "h3ravel",
    "framework",
    "nodejs",
    "typescript",
    "laravel"
  ],
  "scripts": {
    "build": "NODE_ENV=production tsdown --config-loader unrun -c tsdown.default.config.ts",
    "dev": "NODE_ENV=development pnpm tsdown --config-loader unrun -c tsdown.default.config.ts",
    "start": "DIST_DIR=dist node -r source-map-support/register dist/server.js",
    "lint": "eslint . --ext .ts",
    "test": "NODE_NO_WARNINGS=1 NODE_ENV=testing vitest run",
    "test:watch": "NODE_NO_WARNINGS=1 NODE_ENV=testing vitest --watch",
    "coverage": "NODE_NO_WARNINGS=1 NODE_ENV=testing vitest run --coverage",
    "cleanup": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "postinstall": "pnpm prepare"
  },
  "dependencies": {
    "@h3ravel/arquebus": "^1.29.0-alpha.15",
    "@h3ravel/cache": "^11.15.0-alpha.16",
    "@h3ravel/config": "^1.29.0-alpha.16",
    "@h3ravel/console": "^11.15.0-alpha.16",
    "@h3ravel/core": "^1.29.0-alpha.16",
    "@h3ravel/database": "^11.15.0-alpha.16",
    "@h3ravel/filesystem": "^1.29.0-alpha.16",
    "@h3ravel/hashing": "^1.29.0-alpha.16",
    "@h3ravel/http": "^11.15.0-alpha.16",
    "@h3ravel/mail": "^11.15.0-alpha.16",
    "@h3ravel/musket": "^1.29.0-alpha.15",
    "@h3ravel/queue": "^11.15.0-alpha.16",
    "@h3ravel/router": "^1.29.0-alpha.16",
    "@h3ravel/shared": "^1.29.0-alpha.16",
    "@h3ravel/support": "^1.29.0-alpha.16",
    "@h3ravel/url": "^1.29.0-alpha.16",
    "@h3ravel/view": "^1.29.0-alpha.16",
    "@h3ravel/validation": "^1.29.0-alpha.16",
    "@h3ravel/foundation": "^1.29.0-alpha.16",
    "@h3ravel/session": "^1.29.0-alpha.16",
    "@h3ravel/events": "^1.29.0-alpha.16",
    "cross-env": "^10.1.0",
    "h3": "2.0.1-rc.22",
    "reflect-metadata": "^0.2.2",
    "source-map-support": "^0.5.21",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-run": "^3.1.0",
    "@swc/core": "^1.15.41",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "eslint": "^10.4.1",
    "ts-node": "^10.9.2",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.15.0"
}